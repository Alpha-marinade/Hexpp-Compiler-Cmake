{
    "version":6,
    "configurePresets":[
        {
            "name":"base-ninja",
            "hidden":true,
            "generator":"Ninja",
            "binaryDir":"${sourceDir}/build/${presetName}"
        },
        {
            "name":"base-msvc",
            "hidden":true,
            "generator":"Visual Studio 17 2022",
            "binaryDir":"${sourceDir}/build/${presetName}"
        },
        {
            "name":"linux-base",
            "hidden":true,
            "inherits":"base-ninja",
            "condition":{
                "type":"equals",
                "lhs":"${hostSystemName}",
                "rhs":"Linux"
            }
        },
        {
          "name":"windows-gcc-base",
          "hidden":true,
            "inherits":"base-ninja",
            "condition":{
                "type":"equals",
                "lhs":"${hostSystemName}",
                "rhs":"Windows"
            }
        },
         {
          "name":"windows-msvc-base",
          "hidden":true,
            "inherits":"base-msvc",
            "condition":{
                "type":"equals",
                "lhs":"${hostSystemName}",
                "rhs":"Windows"
            }
        },
        {
          "name":"linux-gcc-debug",
          "inherits":"linux-base",
          "displayName":"Linux-Debug(GCC)",
          "cacheVariables":{
            "CMAKE_BUILD_TYPE":"Debug",
            "CMAKE_C_COMPILER":"gcc",
            "CMAKE_CXX_COMPILER":"g++"
          }  
        },
        {
          "name":"linux-gcc-release",
          "inherits":"linux-base",
          "displayName":"Linux-Release(GCC)",
          "cacheVariables":{
            "CMAKE_BUILD_TYPE":"Release",
            "CMAKE_C_COMPILER":"gcc",
            "CMAKE_CXX_COMPILER":"g++"
          }  
        },
        {
          "name":"windows-msvc-debug",
          "inherits":"windows-msvc-base",
          "displayName":"Windows-Debug(MSVC)",
          "cacheVariables":{
            "CMAKE_C_COMPILER":"cl",
            "CMAKE_CXX_COMPILER":"cl"
          }  
        },
         {
          "name":"windows-msvc-release",
          "inherits":"windows-msvc-base",
          "displayName":"Windows-Release(MSVC)",
          "cacheVariables":{
            "CMAKE_C_COMPILER":"cl",
            "CMAKE_CXX_COMPILER":"cl"
          }  
        },
        {
          "name":"windows-gcc-debug",
          "inherits":"windows-gcc-base",
          "displayName":"Windows-Debug(GCC)",
          "cacheVariables":{
            "CMAKE_BUILD_TYPE":"Debug",
            "CMAKE_C_COMPILER":"gcc",
            "CMAKE_CXX_COMPILER":"g++"
          }  
        },
        {
          "name":"windows-gcc-release",
          "inherits":"windows-gcc-base",
          "displayName":"Windows-Release(GCC)",
          "cacheVariables":{
            "CMAKE_BUILD_TYPE":"Release",
            "CMAKE_C_COMPILER":"gcc",
            "CMAKE_CXX_COMPILER":"g++"
          }  
        }
    ],
    "buildPresets":[
        {
            "name":"linux-gcc-debug",
            "configurePreset":"linux-gcc-debug"
        },
        {
            "name":"linux-gcc-release",
            "configurePreset":"linux-gcc-release"
        },
        {
            "name":"windows-gcc-debug",
            "configurePreset":"windows-gcc-debug"
        },
        {
            "name":"windows-gcc-release",
            "configurePreset":"windows-gcc-release"
        },
        {
            "name":"windows-msvc-debug",
            "configurePreset":"windows-msvc-debug",
            "configuration":"Debug"
        },
         {
            "name":"windows-msvc-release",
            "configurePreset":"windows-msvc-release",
            "configuration":"Release"
        }
    ]
}